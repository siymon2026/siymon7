     </svg><span class="text-lg font-medium">YouTube</span> </a> <a id="link-playstore" href="https://play.google.com" target="_blank" rel="noopener noreferrer" class="glass-btn flex items-center gap-4 px-6 py-4 rounded-2xl w-full animate-in" style="animation-delay:0.8s">
     <svg width="24" height="24" viewbox="0 0 24 24" fill="currentColor">
      <path d="M3.61 1.81L13.42 12 3.61 22.19c-.36-.21-.61-.6-.61-1.05V2.86c0-.45.25-.84.61-1.05zM14.85 13.44l2.62 1.53-3.45 3.45-2.62-1.53 3.45-3.45zM21.4 11.13l-2.97 1.73-2.97-1.73L18.43 8.4l2.97 2.73zM14.85 10.56l-3.45-3.45 2.62-1.53 3.45 3.45-2.62 1.53z" />
     </svg><span class="text-lg font-medium">Google Play</span> </a> <a id="link-appstore" href="https://apps.apple.com" target="_blank" rel="noopener noreferrer" class="glass-btn flex items-center gap-4 px-6 py-4 rounded-2xl w-full animate-in" style="animation-delay:0.9s">
     <svg width="24" height="24" viewbox="0 0 24 24" fill="currentColor">
      <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
     </svg><span class="text-lg font-medium">App Store</span> </a> <a id="link-website" href="https://example.com" target="_blank" rel="noopener noreferrer" class="glass-btn flex items-center gap-4 px-6 py-4 rounded-2xl w-full animate-in" style="animation-delay:1s"> <i data-lucide="globe" style="width:24px;height:24px;"></i> <span class="text-lg font-medium">موقعي</span> </a>
   </div><!-- Admin trigger (hidden - triple tap on title) -->
   <p class="text-gray-600 text-xs mt-12 cursor-default" id="adminTrigger">© 2024</p>
  </div><!-- Admin Overlay -->
  <div class="admin-overlay" id="adminOverlay">
   <div class="admin-panel">
    <div id="adminLogin">
     <h2 class="text-xl font-bold text-orange-400 mb-4 text-center">لوحة المشرف</h2><input type="password" id="adminPass" placeholder="الرقم السري" class="w-full px-4 py-3 rounded-xl bg-black/50 border border-gray-700 text-white mb-4 focus:border-orange-500 focus:outline-none"> <button onclick="checkAdmin()" class="w-full py-3 rounded-xl bg-orange-600 hover:bg-orange-500 font-bold transition-all">دخول</button> <button onclick="closeAdmin()" class="w-full py-3 rounded-xl mt-2 border border-gray-700 hover:border-orange-500 transition-all">إغلاق</button>
    </div>
    <div id="adminDashboard" style="display:none;">
     <h2 class="text-xl font-bold text-orange-400 mb-4 text-center">إدارة الصفحة</h2><label class="block text-sm text-gray-400 mb-1">صورة البروفايل</label> <input type="file" id="profileUpload" accept="image/*" class="w-full mb-4 text-sm text-gray-400 file:mr-2 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-orange-600 file:text-white file:cursor-pointer"> <label class="block text-sm text-gray-400 mb-1">صورة الخلفية</label> <input type="file" id="bgUpload" accept="image/*" class="w-full mb-4 text-sm text-gray-400 file:mr-2 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-orange-600 file:text-white file:cursor-pointer"> <label class="block text-sm text-gray-400 mb-1">الاسم</label> <input type="text" id="adminName" class="w-full px-4 py-2 rounded-xl bg-black/50 border border-gray-700 text-white mb-3 focus:border-orange-500 focus:outline-none"> <label class="block text-sm text-gray-400 mb-1">الوصف</label> <input type="text" id="adminDesc" class="w-full px-4 py-2 rounded-xl bg-black/50 border border-gray-700 text-white mb-3 focus:border-orange-500 focus:outline-none"> <label class="block text-sm text-gray-400 mb-1">Instagram</label> <input type="url" id="adminInsta" class="w-full px-4 py-2 rounded-xl bg-black/50 border border-gray-700 text-white mb-3 focus:border-orange-500 focus:outline-none"> <label class="block text-sm text-gray-400 mb-1">Facebook</label> <input type="url" id="adminFb" class="w-full px-4 py-2 rounded-xl bg-black/50 border border-gray-700 text-white mb-3 focus:border-orange-500 focus:outline-none"> <label class="block text-sm text-gray-400 mb-1">TikTok</label> <input type="url" id="adminTiktok" class="w-full px-4 py-2 rounded-xl bg-black/50 border border-gray-700 text-white mb-3 focus:border-orange-500 focus:outline-none"> <label class="block text-sm text-gray-400 mb-1">YouTube</label> <input type="url" id="adminYt" class="w-full px-4 py-2 rounded-xl bg-black/50 border border-gray-700 text-white mb-3 focus:border-orange-500 focus:outline-none"> <label class="block text-sm text-gray-400 mb-1">Google Play</label> <input type="url" id="adminPlay" class="w-full px-4 py-2 rounded-xl bg-black/50 border border-gray-700 text-white mb-3 focus:border-orange-500 focus:outline-none"> <label class="block text-sm text-gray-400 mb-1">App Store</label> <input type="url" id="adminApple" class="w-full px-4 py-2 rounded-xl bg-black/50 border border-gray-700 text-white mb-3 focus:border-orange-500 focus:outline-none"> <label class="block text-sm text-gray-400 mb-1">موقعي</label> <input type="url" id="adminWeb" class="w-full px-4 py-2 rounded-xl bg-black/50 border border-gray-700 text-white mb-3 focus:border-orange-500 focus:outline-none"> <label class="block text-sm text-gray-400 mb-1">تغيير الرقم السري</label> <input type="password" id="adminNewPass" placeholder="رقم سري جديد" class="w-full px-4 py-2 rounded-xl bg-black/50 border border-gray-700 text-white mb-4 focus:border-orange-500 focus:outline-none"> <button onclick="saveAdmin()" class="w-full py-3 rounded-xl bg-orange-600 hover:bg-orange-500 font-bold transition-all mb-2">حفظ</button> <button onclick="closeAdmin()" class="w-full py-3 rounded-xl border border-gray-700 hover:border-orange-500 transition-all">إغلاق</button>
    </div>
   </div>
  </div>
  <script>
    // Default config
    const defaultConfig = {
      page_title: 'اسمك هنا',
      page_subtitle: 'مرحباً بكم في صفحتي',
      instagram_url: 'https://instagram.com',
      facebook_url: 'https://facebook.com',
      tiktok_url: 'https://tiktok.com',
      youtube_url: 'https://youtube.com',
      playstore_url: 'https://play.google.com',
      appstore_url: 'https://apps.apple.com',
      website_url: 'https://example.com',
      background_color: '#0a0a14',
      surface_color: '#1a1a2e',
      text_color: '#ffffff',
      primary_action: '#ff8c00',
      secondary_action: '#ff4500',
      font_family: 'Tajawal',
      font_size: 16
    };

    // Load saved data from localStorage
    function loadData() {
      const saved = localStorage.getItem('landing_data');
      return saved ? JSON.parse(saved) : {};
    }
    function saveData(data) {
      localStorage.setItem('landing_data', JSON.stringify(data));
    }

    // Init page from localStorage
    function initPage() {
      const data = loadData();
      if (data.name) document.getElementById('titleEl').textContent = data.name;
      if (data.desc) document.getElementById('subtitleEl').textContent = data.desc;
      if (data.instagram) document.getElementById('link-instagram').href = data.instagram;
      if (data.facebook) document.getElementById('link-facebook').href = data.facebook;
      if (data.tiktok) document.getElementById('link-tiktok').href = data.tiktok;
      if (data.youtube) document.getElementById('link-youtube').href = data.youtube;
      if (data.playstore) document.getElementById('link-playstore').href = data.playstore;
      if (data.appstore) document.getElementById('link-appstore').href = data.appstore;
      if (data.website) document.getElementById('link-website').href = data.website;
      if (data.profileImg) {
        const img = document.getElementById('profileImg');
        img.src = data.profileImg;
        img.style.display = 'block';
        document.getElementById('profilePlaceholder').style.display = 'none';
      }
      if (data.bgImg) {
        document.body.style.backgroundImage = `url(${data.bgImg})`;
        document.body.style.backgroundSize = 'cover';
        document.body.style.backgroundPosition = 'center';
      }
    }

    // Admin panel
    let tapCount = 0;
    let tapTimer;
    document.getElementById('adminTrigger').addEventListener('click', () => {
      tapCount++;
      clearTimeout(tapTimer);
      tapTimer = setTimeout(() => { tapCount = 0; }, 800);
      if (tapCount >= 3) {
        tapCount = 0;
        document.getElementById('adminOverlay').classList.add('active');
      }
    });

    function checkAdmin() {
      const data = loadData();
      const pass = data.password || '1234';
      if (document.getElementById('adminPass').value === pass) {
        document.getElementById('adminLogin').style.display = 'none';
        document.getElementById('adminDashboard').style.display = 'block';
        // Fill fields
        document.getElementById('adminName').value = data.name || '';
        document.getElementById('adminDesc').value = data.desc || '';
        document.getElementById('adminInsta').value = data.instagram || '';
        document.getElementById('adminFb').value = data.facebook || '';
        document.getElementById('adminTiktok').value = data.tiktok || '';
        document.getElementById('adminYt').value = data.youtube || '';
        document.getElementById('adminPlay').value = data.playstore || '';
        document.getElementById('adminApple').value = data.appstore || '';
        document.getElementById('adminWeb').value = data.website || '';
      } else {
        document.getElementById('adminPass').style.borderColor = '#ef4444';
        document.getElementById('adminPass').value = '';
      }
    }

    function saveAdmin() {
      const data = loadData();
      data.name = document.getElementById('adminName').value;
      data.desc = document.getElementById('adminDesc').value;
      data.instagram = document.getElementById('adminInsta').value;
      data.facebook = document.getElementById('adminFb').value;
      data.tiktok = document.getElementById('adminTiktok').value;
      data.youtube = document.getElementById('adminYt').value;
      data.playstore = document.getElementById('adminPlay').value;
      data.appstore = document.getElementById('adminApple').value;
      data.website = document.getElementById('adminWeb').value;
      const newPass = document.getElementById('adminNewPass').value;
      if (newPass) data.password = newPass;
      saveData(data);
      initPage();
      closeAdmin();
    }

    function closeAdmin() {
      document.getElementById('adminOverlay').classList.remove('active');
      document.getElementById('adminLogin').style.display = 'block';
      document.getElementById('adminDashboard').style.display = 'none';
      document.getElementById('adminPass').value = '';
      document.getElementById('adminPass').style.borderColor = '';
    }

    // Image uploads
    document.getElementById('profileUpload').addEventListener('change', function(e) {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = function(ev) {
        const data = loadData();
        data.profileImg = ev.target.result;
        saveData(data);
        const img = document.getElementById('profileImg');
        img.src = ev.target.result;
        img.style.display = 'block';
        document.getElementById('profilePlaceholder').style.display = 'none';
      };
      reader.readAsDataURL(file);
    });

    document.getElementById('bgUpload').addEventListener('change', function(e) {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = function(ev) {
        const data = loadData();
        data.bgImg = ev.target.result;
        saveData(data);
        document.body.style.backgroundImage = `url(${ev.target.result})`;
        document.body.style.backgroundSize = 'cover';
        document.body.style.backgroundPosition = 'center';
      };
      reader.readAsDataURL(file);
    });

    // Element SDK
    function applyConfig(config) {
      document.getElementById('titleEl').textContent = config.page_title || defaultConfig.page_title;
      document.getElementById('subtitleEl').textContent = config.page_subtitle || defaultConfig.page_subtitle;
      document.getElementById('link-instagram').href = config.instagram_url || defaultConfig.instagram_url;
      document.getElementById('link-facebook').href = config.facebook_url || defaultConfig.facebook_url;
      document.getElementById('link-tiktok').href = config.tiktok_url || defaultConfig.tiktok_url;
      document.getElementById('link-youtube').href = config.youtube_url || defaultConfig.youtube_url;
      document.getElementById('link-playstore').href = config.playstore_url || defaultConfig.playstore_url;
      document.getElementById('link-appstore').href = config.appstore_url || defaultConfig.appstore_url;
      document.getElementById('link-website').href = config.website_url || defaultConfig.website_url;

      // Colors
      document.body.style.backgroundColor = config.background_color || defaultConfig.background_color;
      document.getElementById('titleEl').style.color = config.primary_action || defaultConfig.primary_action;
      document.getElementById('subtitleEl').style.color = config.text_color || defaultConfig.text_color;

      // Font
      const font = config.font_family || defaultConfig.font_family;
      const size = config.font_size || defaultConfig.font_size;
      document.getElementById('titleEl').style.fontFamily = `${font}, sans-serif`;
      document.getElementById('titleEl').style.fontSize = `${size * 1.8}px`;
      document.getElementById('subtitleEl').style.fontFamily = `${font}, sans-serif`;
      document.getElementById('subtitleEl').style.fontSize = `${size * 1.1}px`;
      document.querySelectorAll('.glass-btn span').forEach(el => {
        el.style.fontFamily = `${font}, sans-serif`;
        el.style.fontSize = `${size}px`;
      });
    }

    if (window.elementSdk) {
      window.elementSdk.init({
        defaultConfig,
        onConfigChange: async (config) => { applyConfig(config); },
        mapToCapabilities: (config) => ({
          recolorables: [
            { get: () => config.background_color || defaultConfig.background_color, set: (v) => { config.background_color = v; window.elementSdk.setConfig({ background_color: v }); } },
            { get: () => config.surface_color || defaultConfig.surface_color, set: (v) => { config.surface_color = v; window.elementSdk.setConfig({ surface_color: v }); } },
            { get: () => config.text_color || defaultConfig.text_color, set: (v) => { config.text_color = v; window.elementSdk.setConfig({ text_color: v }); } },
            { get: () => config.primary_action || defaultConfig.primary_action, set: (v) => { config.primary_action = v; window.elementSdk.setConfig({ primary_action: v }); } },
            { get: () => config.secondary_action || defaultConfig.secondary_action, set: (v) => { config.secondary_action = v; window.elementSdk.setConfig({ secondary_action: v }); } }
          ],
          borderables: [],
          fontEditable: { get: () => config.font_family || defaultConfig.font_family, set: (v) => { config.font_family = v; window.elementSdk.setConfig({ font_family: v }); } },
          fontSizeable: { get: () => config.font_size || defaultConfig.font_size, set: (v) => { config.font_size = v; window.elementSdk.setConfig({ font_size: v }); } }
        }),
        mapToEditPanelValues: (config) => new Map([
          ['page_title', config.page_title || defaultConfig.page_title],
          ['page_subtitle', config.page_subtitle || defaultConfig.page_subtitle],
          ['instagram_url', config.instagram_url || defaultConfig.instagram_url],
          ['facebook_url', config.facebook_url || defaultConfig.facebook_url],
          ['tiktok_url', config.tiktok_url || defaultConfig.tiktok_url],
          ['youtube_url', config.youtube_url || defaultConfig.youtube_url],
          ['playstore_url', config.playstore_url || defaultConfig.playstore_url],
          ['appstore_url', config.appstore_url || defaultConfig.appstore_url],
          ['website_url', config.website_url || defaultConfig.website_url]
        ])
      });
    }

    initPage();
